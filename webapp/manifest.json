{
    "_version": "1.58.0",
    "sap.app":{
        "id": "am.hr.payroll",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "dataSources": {
            "appliedService": {
                "uri": "/sap/opu/odata/sap/ZAM_AB_SRV/",
                "type": "OData",
                "settings": {
                    "odataVersion": "2.0"
                }
            }
        },
        "applicationVersion": {
            "version": "1.0.0"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}"
    },
    "sap.ui":{
        "technology": "UI5",
        "fullWidth": true,
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }        
    },
    "sap.ui5":{
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "rootView": {
            "id": "idRootView",
            "type": "XML",
            "viewName": "am.hr.payroll.view.App"
        },
        "routing": {
            "config":{
                "routerClass": "sap.m.routing.Router",
                "viewPath": "am.hr.payroll.view",
                "viewType": "XML",
                "controlId": "appCon"
            },
            "routes":[
                {
                    "pattern": "",
                    "name": "spiderman",
                    "target": ["donald", "trump"]
                },
                {
                    "pattern": "fruit/{path}",
                    "name": "superman",
                    "target": ["donald", "putin"]
                },
                {
                    "pattern": "supplier/{suppId}",
                    "name": "baloo",
                    "target": ["donald", "modi"]
                },
                {
                    "pattern": "manageProduct",
                    "name": "add",
                    "target": ["donald", "xijing"]
                }
            ],
            "targets": {
                "donald":{
                    "viewName": "View1",
                    "viewId": "idView1",
                    "controlAggregation": "masterPages",
                    "clearControlAggregation": true
                },
                "trump":{
                    "viewName": "Empty",
                    "viewId": "idEmpty",
                    "controlAggregation": "detailPages",
                    "clearControlAggregation": true
                },
                "putin":{
                    "viewName": "View2",
                    "viewId": "idView2",
                    "controlAggregation": "detailPages",
                    "clearControlAggregation": true
                },
                "modi":{
                    "viewName": "View3",
                    "viewId": "idView3",
                    "controlAggregation": "detailPages",
                    "clearControlAggregation": true
                },
                "xijing":{
                    "viewName": "Add",
                    "viewId": "idAdd",
                    "controlAggregation": "detailPages",
                    "clearControlAggregation": true
                }
            }
        },

        "dependencies": {
            "minUI5Version": "1.135.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.ui.layout": {}
            }
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "am.hr.payroll.i18n.i18n"
                }
            },
            "" :{
                "type": "sap.ui.model.odata.v2.ODataModel",
                "dataSource": "appliedService"
            },
            "local": {
                "type": "sap.ui.model.json.JSONModel",
                "uri": "model/data.json"
            }
        }
    }
}