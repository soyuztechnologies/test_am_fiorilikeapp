<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:f="sap.ui.layout.form">
    <Table id="zkas" items="{/supplier}" mode="SingleSelectLeft" itemPress="onSelTableRow">
        <headerToolbar>
            <Toolbar >
                <ToolbarSpacer ></ToolbarSpacer>
                <Button icon="sap-icon://filter" press="onFilter"></Button>
                <Button icon="sap-icon://iphone" press="onCancelFilter"></Button>
            </Toolbar>
        </headerToolbar>
                            <columns>
                                <Column>
                                    <header>
                                        <Label text="Supplier Name"></Label>
                                    </header>
                                </Column>

                                <Column minScreenWidth="Tablet">
                                    <header>
                                        <Label text="Since When"></Label>
                                    </header>
                                </Column>

                                <Column>
                                    <header>
                                        <Label text="City"></Label>
                                    </header>
                                </Column>

                                <Column minScreenWidth="Tablet">
                                    <header>
                                        <Label text="Contact Details"></Label>
                                    </header>
                                </Column>
                            
                            </columns>
                            <ColumnListItem type="Navigation">
                                <cells>
                                    <Text text="{name}" />
                                    <Text text="{sinceWhen}" />
                                    <Input value="{city}" showValueHelp="true" valueHelpRequest="onF4Help"></Input>
                                    <Text text="{person} {contactNo}" />
                                </cells>
                            </ColumnListItem>
                        </Table>
</core:FragmentDefinition>