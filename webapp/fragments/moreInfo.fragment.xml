<core:FragmentDefinition xmlns:core="sap.ui.core" xmlns="sap.m" xmlns:f="sap.ui.layout.form">
    <f:SimpleForm>
        <Label text="Name"></Label>
        <Text text="{NAME}" />
        <Label text="Type"></Label>
        <Text text="{CATEGORY}" />
        <Label text="Cost"></Label>
        <Text text="{PRICE} {CURRENCY_CODE}" />
        <Label text="Supplier"></Label>
        <Text text="{SUPPLIER_ID}  -> {SUPPLIER_NAME}" />

        <Label text="Supplier Location"></Label>
        <Text text="{To_Supplier/BUILDING}  -> {To_Supplier/CITY} {To_Supplier/COUNTRY}" />
        <Label text="Contact"></Label>
        <Text text="{To_Supplier/EMAIL_ADDRESS}  -> {To_Supplier/PHONE_NUMBER}" />

    </f:SimpleForm>
</core:FragmentDefinition>